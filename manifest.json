{
  "manifest_version": 3,
  "name": "CourtListener Copy Citation",
  "version": "1.0.0",
  "description": "Copy a properly formatted citation with pincite from CourtListener opinion pages.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.courtlistener.com/opinion/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["clipboardWrite"],
  "browser_specific_settings": {
    "gecko": {
      "id": "courtlistener-copy-citation@jonjonrankin.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
